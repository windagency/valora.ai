# use-node-version=22.21.0
# node-version=22.21.0
engine-strict=true
# enable-pre-post-scripts=true

# Prevent lockfile mutations — forces intentional updates via `pnpm update`
frozen-lockfile=true

# Block lifecycle scripts from ALL dependencies (postinstall, install, preinstall)
# Root project scripts (prepare, prebuild, etc.) are unaffected
ignore-scripts=true
